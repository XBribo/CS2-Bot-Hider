<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <AssemblyName>BotHiderImpl</AssemblyName>
    <RootNamespace>BotHiderImpl</RootNamespace>
    <CopyLocalLockFileAssemblies>false</CopyLocalLockFileAssemblies>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <NoWarn>CA1416</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="CounterStrikeSharp.API" Version="1.0.368">
      <Private>false</Private>
      <ExcludeAssets>runtime</ExcludeAssets>
    </PackageReference>
    <PackageReference Include="Lib.Harmony" Version="2.3.3" GeneratePathProperty="true">
      <Private>false</Private>
    </PackageReference>
    <ProjectReference Include="..\BotHiderApi\BotHiderApi.csproj">
      <Private>false</Private>
    </ProjectReference>
  </ItemGroup>

  <!-- Harmony is a shared lib: emit it only under shared/0Harmony (-> counterstrikesharp/shared),
       never next to BotHiderImpl.dll. -->
  <Target Name="CopyHarmony" AfterTargets="Build;Publish">
    <Copy SourceFiles="$(PkgLib_Harmony)\lib\net8.0\0Harmony.dll"
          DestinationFolder="$(OutDir)shared\0Harmony"
          SkipUnchangedFiles="true" />
  </Target>

</Project>
